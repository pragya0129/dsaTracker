# ──────────────────────────────────────────────────────────────────────────
# AlgoLedger — runtime config (TEMPLATE)
#
# Copy to application.properties for local dev. For production / Render
# deploys, leave this file alone (it's committed) and set the corresponding
# env vars on the host; every property here reads from an env var first.
# ──────────────────────────────────────────────────────────────────────────

# ── HTTP port ─────────────────────────────────────────────────────────────
# Render / Railway / Fly inject a PORT env var at runtime. Default 8080
# for local dev (no env var needed — just run the jar / Docker image).
server.port=${PORT:8080}

# ── Database (PostgreSQL) ─────────────────────────────────────────────────
spring.datasource.driver-class-name=org.postgresql.Driver
spring.datasource.url=${DB_URL:jdbc:postgresql://localhost:5432/algoledger}
spring.datasource.username=${DB_USER:postgres}
spring.datasource.password=${DB_PASSWORD:postgres}

# Use `update` on first deploy so Hibernate creates tables, then flip to
# `validate` (via SPRING_JPA_HIBERNATE_DDL_AUTO=validate) to freeze schema.
spring.jpa.hibernate.ddl-auto=${SPRING_JPA_HIBERNATE_DDL_AUTO:update}
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl
spring.jpa.show-sql=false

# ── Auth ──────────────────────────────────────────────────────────────────
app.jwt.expiration-ms=${APP_JWT_EXPIRATION_MS:86400000}
# REQUIRED in production. Generate with:  openssl rand -base64 48
app.jwt.secret=${APP_JWT_SECRET:}

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, no trailing slashes.
# Example for a Vercel deploy:
#   APP_CORS_ORIGINS=https://your-app.vercel.app,https://algoledger.com
app.cors.origins=${APP_CORS_ORIGINS:http://localhost:5173,http://127.0.0.1:5173}

# ── Web base URL (used in email CTAs) ─────────────────────────────────────
app.web.base-url=${APP_WEB_BASE_URL:http://localhost:5173}

# ── Signup verification ───────────────────────────────────────────────────
# true  → signups require email OTP
# false → signups create the account directly (useful before your Resend
#         sending domain is verified)
app.signup.verification-enabled=${APP_SIGNUP_VERIFICATION_ENABLED:true}

# ── Mail (Resend) ─────────────────────────────────────────────────────────
# provider: `resend` sends real email; `logging` writes to the app log.
app.mail.provider=${APP_MAIL_PROVIDER:logging}
app.mail.from=${APP_MAIL_FROM:AlgoLedger <onboarding@resend.dev>}
# Get an API key at https://resend.com/api-keys (free tier: 3000/month).
app.mail.resend.api-key=${APP_MAIL_RESEND_API_KEY:}
